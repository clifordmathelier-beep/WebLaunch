---
import { Image } from 'astro:assets';
import twoWomenSittingImage from '/src/assets/images/family4.jpg';

const credentials = [
  'Child & Adolescent Development',
  'Bilingualism & Multilingual Parenting',
  'Multicultural Family Dynamics',
  'Parent-Child Interaction Therapy (PCIT)',
];
---

<section id="bio" class="bio">
  <div class="section-container">
    <span class="section-tag">MEET YOUR CONSULTANT</span>
    <h2 class="section-title">Clarity for the moments that matter most.</h2>
    <div class="bio-container">
      <div class="bio-image-wrapper">
        <Image
          src={twoWomenSittingImage}
          alt="Family consultation."
          class="media"
        />
      </div>
      <div class="bio-content">
        <h3 class="section-subtitle bio-name">Marie-Christine André, PhD</h3>
        <p class="bio-text">
          I'm a licensed clinical psychologist with over 15 years of experience supporting
          children, adolescents, and the families who raise them. My work sits at the
          intersection of child development, bilingualism, and multicultural family life.
        </p>
        <p class="bio-text">
          Whether your child is navigating two languages, two cultures, or simply a stage
          that doesn't match the textbook — I can help. One focused session to cut through
          the noise and give you a clear, confident path forward.
        </p>
        <ul class="bio-credentials" aria-label="Areas of expertise">
          {credentials.map(item => (
            <li class="bio-credential-item">
              <span class="bio-credential-dot" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .bio-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--px-64);
    align-items: center;
  }

  .bio-image-wrapper {
    width: 100%;
    height: 100%;
    min-height: 28.125rem;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .bio-content {
    max-width: 37.5rem;
  }

  .bio-name {
    margin-bottom: var(--px-20);
  }

  .bio-text {
    margin-bottom: var(--px-24);
    color: var(--color-text-dark);
  }

  .bio-credentials {
    list-style: none;
    padding: 0;
    margin: var(--px-32) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--px-12);
  }

  .bio-credential-item {
    display: flex;
    align-items: center;
    gap: var(--px-12);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .bio-credential-dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background-color: var(--color-focus);
    flex-shrink: 0;
  }

  @media screen and (max-width: 64rem) {
    .bio-container {
      gap: var(--px-32);
    }

    .bio-image-wrapper {
      min-height: 25rem;
    }

    .bio-content {
      max-width: 100%;
    }
  }

  @media screen and (max-width: 48rem) {
    .bio-container {
      grid-template-columns: 1fr;
      gap: var(--px-32);
    }

    .bio-image-wrapper {
      min-height: 21.875rem;
      order: -1;
    }
  }
</style>
